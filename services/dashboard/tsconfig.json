{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "jsx": "preserve",
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/stores/*": ["./src/stores/*"],
      "@/views/*": ["./src/views/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/composables/*": ["./src/composables/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.vue"],
  "exclude": ["dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../types" },
    { "path": "../core" }
  ]
}