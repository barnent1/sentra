{
  "name": "@sentra/api-gateway",
  "version": "1.0.0",
  "description": "SENTRA API Gateway Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0",
    "express-slow-down": "^1.6.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.9.2",
    "winston": "^3.10.0",
    "dotenv": "^16.3.1",
    "http-proxy-middleware": "^2.0.6",
    "redis": "^4.6.7",
    "pg": "^8.11.3",
    "amqplib": "^0.10.3",
    "ws": "^8.13.0",
    "prom-client": "^14.2.0",
    "node-vault": "^0.10.2",
    "uuid": "^9.0.0"
