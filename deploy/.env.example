# Sentra Server Configuration

# Pushover Integration
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# OpenAI API for TTS
OPENAI_API_KEY=sk-your_openai_api_key_here

# Server Configuration
SENTRA_PUBLIC_URL=https://sentra.yourdomain.com
SENTRA_API_TOKEN=your_secure_api_token_here

# Database Configuration
POSTGRES_USER=sentra
POSTGRES_PASSWORD=secure_postgres_password_here
POSTGRES_DB=sentra
DATABASE_URL=postgresql://sentra:secure_postgres_password_here@postgres:5432/sentra

# Optional: Custom domain for Caddy
DOMAIN=sentra.yourdomain.com

# Development
DEBUG=false