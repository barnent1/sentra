# Sentra Production Environment
# Edit these values with your actual credentials

# Pushover Integration (required for notifications)
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# OpenAI API for TTS (required for voice)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Server Configuration
SENTRA_PUBLIC_URL=http://52.23.29.2
SENTRA_API_TOKEN=generated-secure-token-12345
NODE_ENV=production
DEBUG=false

# Database Configuration
POSTGRES_USER=sentra
POSTGRES_PASSWORD=secure-postgres-password-change-me
POSTGRES_DB=sentra
DATABASE_URL=postgresql://sentra:secure-postgres-password-change-me@postgres:5432/sentra

# Domain (optional - set if using custom domain)
DOMAIN=52.23.29.2