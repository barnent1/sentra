{
  "name": "@sentra/api",
  "version": "1.0.0",
  "description": "TypeScript API layer for Sentra Evolutionary Agent System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/example.ts",
    "start": "node dist/example.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "example": "tsx src/example.ts",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration --testPathIgnorePatterns=load",
    "test:load": "jest --testPathPattern=load",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docs": "echo 'API documentation available at http://localhost:3001/api'",
    "health": "curl -s http://localhost:3001/health | jq",
    "metrics": "curl -s http://localhost:3001/api/metrics | jq"
  },
  "dependencies": {
    "@sentra/core": "*",
    "@sentra/types": "*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.17.2",
    "pino-http": "^8.6.1",
    "postgres": "^3.4.3",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "supertest": "^6.3.4",
    "testcontainers": "^10.7.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ]
}
