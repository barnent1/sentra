# SENTRA Production Environment Configuration

# Domain Configuration
DOMAIN=sentra.example.com
ROOT_URL=https://sentra.example.com
SENTRA_PUBLIC_URL=https://sentra.example.com

# Database Configuration
POSTGRES_USER=sentra_prod
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=sentra_production
DATABASE_URL=postgresql://sentra_prod:CHANGE_THIS_SECURE_PASSWORD@postgres:5432/sentra_production

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# API Configuration
SENTRA_API_TOKEN=CHANGE_THIS_API_TOKEN
JWT_SECRET=CHANGE_THIS_JWT_SECRET_KEY

# External Services
OPENAI_API_KEY=your_openai_api_key_here
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# SSL Configuration
LETSENCRYPT_EMAIL=admin@sentra.example.com

# Monitoring and Alerts
ALERT_EMAIL=alerts@sentra.example.com
ALERT_WEBHOOK=https://hooks.slack.com/services/your/webhook/url

# Grafana Configuration
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# Application Configuration
NODE_ENV=production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# Security
CORS_ORIGIN=https://sentra.example.com,https://api.sentra.example.com,https://mobile.sentra.example.com
ALLOWED_HOSTS=sentra.example.com,api.sentra.example.com,mobile.sentra.example.com

# Performance
MAX_REQUEST_SIZE=50mb
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# File Storage
DATA_PATH=/var/sentra
BACKUP_PATH=/var/sentra/backups

# Docker Configuration
COMPOSE_PROJECT_NAME=sentra-prod

# Deployment Configuration
DEPLOY_HOST=your-production-server.com
DEPLOY_USER=deploy
DEPLOY_PORT=22
DEPLOY_PEM_PATH=~/.ssh/sentra_deploy_key