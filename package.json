{
  "name": "sentra",
  "version": "1.0.0",
  "description": "AI Code Engineering Platform with Multi-Agent Orchestration",
  "main": "index.js",
  "scripts": {
    "dev": "docker-compose up -d",
    "build": "docker-compose build",
    "start": "docker-compose up",
    "stop": "docker-compose down",
    "logs": "docker-compose logs -f",
    "test": "jest --projects services/*/jest.config.js",
    "test:e2e": "cypress run",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "cd infrastructure/database && npm run migrate",
    "db:seed": "cd infrastructure/database && npm run seed",
    "setup": "npm install && npm run db:migrate && npm run db:seed",
    "clean": "docker-compose down -v && docker system prune -f"
  },
  "workspaces": [
    "services/*",
    "agents/*",
    "shared/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "cypress": "^13.0.0"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "ai",
    "code-engineering",
    "multi-agent",
    "orchestration",
    "microservices",
    "context-preservation"
  ],
  "author": "SENTRA Development Team",
  "license": "MIT"
}