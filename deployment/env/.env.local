# SENTRA Local Development Environment Configuration

# Domain Configuration
DOMAIN=localhost
ROOT_URL=http://localhost:3000
SENTRA_PUBLIC_URL=http://localhost:8000

# Database Configuration
POSTGRES_USER=sentra_dev
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=sentra_development
DATABASE_URL=postgresql://sentra_dev:dev_password_123@localhost:5432/sentra_development

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# API Configuration
SENTRA_API_TOKEN=dev_api_token_123
JWT_SECRET=dev_jwt_secret_key_123

# External Services (use development keys)
OPENAI_API_KEY=your_dev_openai_api_key_here
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# SSL Configuration (not used in local)
LETSENCRYPT_EMAIL=dev@localhost

# Monitoring and Alerts (disabled for local)
ALERT_EMAIL=
ALERT_WEBHOOK=

# Grafana Configuration
GRAFANA_PASSWORD=admin

# Application Configuration
NODE_ENV=development
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug

# Security (very permissive for development)
CORS_ORIGIN=*
ALLOWED_HOSTS=*

# Performance (no restrictions for development)
MAX_REQUEST_SIZE=1GB
RATE_LIMIT_WINDOW=1000
RATE_LIMIT_MAX=1000000

# File Storage
DATA_PATH=./data
BACKUP_PATH=./data/backups

# Docker Configuration
COMPOSE_PROJECT_NAME=sentra-dev

# Hot Reload (development only)
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Development Tools
VITE_HMR_PORT=3100
PLAYWRIGHT_HEADLESS=false