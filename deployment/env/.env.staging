# SENTRA Staging Environment Configuration

# Domain Configuration
DOMAIN=staging.sentra.example.com
ROOT_URL=http://staging.sentra.example.com:8080
SENTRA_PUBLIC_URL=http://staging.sentra.example.com:8080
SENTRA_STAGING_URL=http://staging.sentra.local:8080

# Database Configuration
POSTGRES_USER=sentra_staging
POSTGRES_PASSWORD=staging_password_123
POSTGRES_DB=sentra_staging
DATABASE_URL=postgresql://sentra_staging:staging_password_123@postgres:5432/sentra_staging

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=staging_redis_password

# API Configuration
SENTRA_API_TOKEN=staging_api_token_123
JWT_SECRET=staging_jwt_secret_key_123

# External Services (use test/development keys)
OPENAI_API_KEY=your_test_openai_api_key_here
PUSHOVER_APP_TOKEN=your_test_pushover_app_token_here
PUSHOVER_USER_KEY=your_test_pushover_user_key_here

# SSL Configuration (not used in staging)
LETSENCRYPT_EMAIL=staging@sentra.example.com

# Monitoring and Alerts
ALERT_EMAIL=staging-alerts@sentra.example.com
ALERT_WEBHOOK=https://hooks.slack.com/services/your/staging/webhook/url

# Grafana Configuration
GRAFANA_PASSWORD=staging_grafana_password

# Application Configuration
NODE_ENV=staging
ENVIRONMENT=staging
DEBUG=true
LOG_LEVEL=debug

# Security (more permissive for testing)
CORS_ORIGIN=*
ALLOWED_HOSTS=*

# Performance (less restrictive for testing)
MAX_REQUEST_SIZE=100mb
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10000

# File Storage
DATA_PATH=/tmp/sentra-staging
BACKUP_PATH=/tmp/sentra-staging/backups

# Docker Configuration
COMPOSE_PROJECT_NAME=sentra-staging

# Deployment Configuration
DEPLOY_HOST=staging-server.example.com
DEPLOY_USER=deploy
DEPLOY_PORT=22
DEPLOY_PEM_PATH=~/.ssh/sentra_staging_key