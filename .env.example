# Environment Configuration
NODE_ENV=development

# Database Configuration
POSTGRES_PASSWORD=sentra_secure_password_2024
DATABASE_URL=postgresql://sentra_user:sentra_secure_password_2024@postgres:5432/sentra

# Redis Configuration
REDIS_PASSWORD=sentra_redis_secure_2024
REDIS_URL=redis://:sentra_redis_secure_2024@redis:6379

# Message Queue Configuration
RABBITMQ_PASSWORD=sentra_rabbit_secure_2024
RABBITMQ_URL=amqp://sentra:sentra_rabbit_secure_2024@rabbitmq:5672

# Security Configuration
JWT_SECRET=sentra_jwt_super_secret_key_2024_change_in_production
VAULT_ROOT_TOKEN=sentra_vault_root_token_2024
VAULT_URL=http://vault:8200

# API Configuration
API_GATEWAY_PORT=3000
AGENT_ORCHESTRATOR_PORT=3001
CONTEXT_ENGINE_PORT=3002
QUALITY_GUARDIAN_PORT=3003
TIMELINE_INTELLIGENCE_PORT=3004
AUTH_SERVICE_PORT=3005

# External Services
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GITHUB_TOKEN=your_github_token_here

# Monitoring Configuration
GRAFANA_PASSWORD=sentra_grafana_admin_2024
PGADMIN_PASSWORD=sentra_pgadmin_admin_2024

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Settings
ENCRYPTION_KEY=sentra_encryption_key_32_chars_long
HMAC_SECRET=sentra_hmac_secret_key_for_integrity

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=sentra_session_secret_key_2024
SESSION_TIMEOUT=3600000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=js,ts,tsx,jsx,py,java,go,rs,cpp,c,h

# Agent Configuration
MAX_CONCURRENT_AGENTS=8
AGENT_TIMEOUT_MS=300000
CONTEXT_RETENTION_DAYS=30

# Performance Configuration
CACHE_TTL_SECONDS=3600
MAX_CONTEXT_SIZE_MB=50
CONNECTION_POOL_SIZE=20