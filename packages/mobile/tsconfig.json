{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "jsx": "preserve",
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/types": ["./src/types/index"],
      "@/stores/*": ["./src/stores/*"],
      "@/components/*": ["./src/components/*"],
      "@/views/*": ["./src/views/*"],
      "@/utils/*": ["./src/utils/*"]
    }
  },
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "references": [
    { "path": "../types" },
    { "path": "../core" },
    { "path": "./tsconfig.node.json" }
  ]
}