{
  "name": "@sentra/cli",
  "version": "1.0.0",
  "description": "Command-line interface for Sentra Evolutionary Agent System",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentra": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/cli.ts",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@sentra/core": "*",
    "@sentra/types": "*",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "boxen": "^7.1.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "files": [
    "dist"
  ]
}